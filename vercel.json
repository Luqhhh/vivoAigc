{
  "version": 2,
  "buildCommand": "pnpm --filter @codemotion/api build && pnpm --dir apps/web build",
  "installCommand": "pnpm install --frozen-lockfile",
  "builds": [
    {
      "src": "apps/web/dist",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "apps/api/dist/**"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
