{
  "name": "codemotion",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "node \"%npm_execpath%\" --filter @codemotion/api dev",
    "dev:api": "node \"%npm_execpath%\" --filter @codemotion/api dev",
    "dev:web": "node \"%npm_execpath%\" --filter @codemotion/web dev",
    "build": "node \"%npm_execpath%\" --filter @codemotion/api build && node \"%npm_execpath%\" --filter @codemotion/web build",
    "test": "node \"%npm_execpath%\" --filter @codemotion/api test && node \"%npm_execpath%\" --filter @codemotion/web test",
    "test:api": "node \"%npm_execpath%\" --filter @codemotion/api test",
    "test:web": "node \"%npm_execpath%\" --filter @codemotion/web test"
  }
}
