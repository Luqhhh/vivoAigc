{
  "name": "codemotion",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "pnpm --filter @codemotion/api dev",
    "dev:api": "pnpm --filter @codemotion/api dev",
    "dev:web": "pnpm --filter @codemotion/web dev",
    "build": "pnpm --filter @codemotion/api build && pnpm --filter @codemotion/web build",
    "test": "pnpm --filter @codemotion/api test && pnpm --filter @codemotion/web test",
    "test:api": "pnpm --filter @codemotion/api test",
    "test:web": "pnpm --filter @codemotion/web test"
  }
}
